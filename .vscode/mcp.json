{
  "servers": {
    "aspire": {
      "type": "stdio",
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "playwright-mcp",
      "args": [
        "--headless",
        "--isolated",
        "--no-sandbox"
      ]
    }
  }
}
