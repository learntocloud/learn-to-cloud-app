# -----------------------------------------------------------------------------
# Learn to Cloud - Terraform Variables Example
# -----------------------------------------------------------------------------
# Copy this file to terraform.tfvars.local and fill in your values.
# The .local file is gitignored and safe for secrets.
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars.local
#   # Edit terraform.tfvars.local with your values
#   terraform plan -var-file="terraform.tfvars.local"
# -----------------------------------------------------------------------------

# Required - Azure subscription
subscription_id = "your-azure-subscription-id"

# Required - PostgreSQL Microsoft Entra admin
# Use a DBA/break-glass Entra group, not the API managed identity.
postgres_entra_admin_object_id      = "00000000-0000-0000-0000-000000000000"
postgres_entra_admin_principal_name = "Learn to Cloud PostgreSQL Admins"
# postgres_entra_admin_principal_type = "Group"

# Optional - PostgreSQL migration role mapped to the migration job identity.
# Defaults to "ltc-postgres-migrations-<environment>".
# postgres_migration_role = "ltc-postgres-migrations-dev"

# Optional - PostgreSQL runtime role mapped to the API managed identity
# postgres_api_runtime_role = "ltc_api_runtime_dev"

# Optional - PostgreSQL runtime role mapped to the verification Functions managed identity
# postgres_verification_functions_role = "ltc_verification_functions_dev"

# Optional - CIDR ranges allowed to connect to Durable Task Scheduler.
# durable_task_scheduler_ip_allowlist = ["0.0.0.0/0"]

# Required - GitHub OAuth App client ID (create at https://github.com/settings/developers)
github_client_id = "Ov23xxx"

# Runtime secrets are stored in Key Vault, not tfvars:
# - github-client-secret
# - github-token
# - session-secret-key
# - labs-verification-secret

# Optional - Override defaults
# location    = "centralus"
# environment = "dev"
# alert_emails = ["learntocloud@gmail.com"]
