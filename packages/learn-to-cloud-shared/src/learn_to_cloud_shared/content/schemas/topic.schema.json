{
  "$defs": {
    "LearningObjective": {
      "description": "A learning objective for a topic.",
      "properties": {
        "order": {
          "title": "Order",
          "type": "integer"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "uuid": {
          "format": "uuid",
          "title": "Uuid",
          "type": "string"
        }
      },
      "required": [
        "uuid",
        "text",
        "order"
      ],
      "title": "LearningObjective",
      "type": "object"
    },
    "LearningStep": {
      "description": "A learning step within a topic.",
      "properties": {
        "action": {
          "anyOf": [
            {
              "$ref": "#/$defs/StepAction"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "checklist": {
          "items": {
            "type": "string"
          },
          "title": "Checklist",
          "type": "array"
        },
        "code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "done_when": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Done When"
        },
        "options": {
          "items": {
            "$ref": "#/$defs/ProviderOption"
          },
          "title": "Options",
          "type": "array"
        },
        "order": {
          "title": "Order",
          "type": "integer"
        },
        "slug": {
          "title": "Slug",
          "type": "string"
        },
        "tips": {
          "items": {
            "$ref": "#/$defs/TipItem"
          },
          "title": "Tips",
          "type": "array"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "uuid": {
          "format": "uuid",
          "title": "Uuid",
          "type": "string"
        }
      },
      "required": [
        "uuid",
        "slug",
        "order"
      ],
      "title": "LearningStep",
      "type": "object"
    },
    "ProviderOption": {
      "description": "Cloud provider or platform-specific option for a learning step.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "url": {
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "title",
        "url"
      ],
      "title": "ProviderOption",
      "type": "object"
    },
    "StepAction": {
      "description": "Categorical action label for a learning step.\n\nDrives the colored action badge in the step UI. Authored in YAML as\n``action: 'Practice:'`` (capitalized, trailing colon) for readability;\nthe schema validator normalizes to the lowercase enum value at load\ntime. The trailing colon is purely a YAML-author affordance and\nnever reaches the rendered UI.",
      "enum": [
        "build",
        "explore",
        "note",
        "practice",
        "read",
        "reflect",
        "review",
        "watch"
      ],
      "title": "StepAction",
      "type": "string"
    },
    "TipItem": {
      "description": "A tip, note, or warning callout for a learning step.",
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/TipType",
          "default": "tip"
        }
      },
      "required": [
        "text"
      ],
      "title": "TipItem",
      "type": "object"
    },
    "TipType": {
      "description": "Categorical type for a callout/tip attached to a learning step.",
      "enum": [
        "tip",
        "note",
        "warning",
        "important"
      ],
      "title": "TipType",
      "type": "string"
    }
  },
  "description": "A topic within a phase.\n\nDisplay order is determined by the topic's position in the parent\nphase's ``topics:`` slug list (in ``_phase.yaml``); the loader\ninjects ``order`` based on that position. Topic YAML files do not\ncarry an ``order`` field -- two sources of truth would inevitably\ndrift (issue #463).",
  "properties": {
    "description": {
      "title": "Description",
      "type": "string"
    },
    "learning_objectives": {
      "items": {
        "$ref": "#/$defs/LearningObjective"
      },
      "title": "Learning Objectives",
      "type": "array"
    },
    "learning_steps": {
      "items": {
        "$ref": "#/$defs/LearningStep"
      },
      "title": "Learning Steps",
      "type": "array"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "order": {
      "title": "Order",
      "type": "integer"
    },
    "slug": {
      "title": "Slug",
      "type": "string"
    },
    "uuid": {
      "format": "uuid",
      "title": "Uuid",
      "type": "string"
    }
  },
  "required": [
    "uuid",
    "slug",
    "name",
    "description",
    "order",
    "learning_steps"
  ],
  "title": "Topic",
  "type": "object"
}
