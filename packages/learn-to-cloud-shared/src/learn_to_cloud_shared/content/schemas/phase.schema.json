    "Topic": {
      "description": "A topic within a phase.\n\nDisplay order is determined by the topic's position in the parent\nphase's ``topics:`` slug list (in ``_phase.yaml``); the loader\ninjects ``order`` based on that position. Topic YAML files do not\ncarry an ``order`` field -- two sources of truth would inevitably\ndrift (issue #463).",
      "properties": {
        "description": {
          "title": "Description",
          "type": "string"
        },
        "learning_objectives": {
          "items": {
            "$ref": "#/$defs/LearningObjective"
          },
          "title": "Learning Objectives",
          "type": "array"
        },
        "learning_steps": {
          "items": {
            "$ref": "#/$defs/LearningStep"
          },
          "title": "Learning Steps",
          "type": "array"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "order": {
          "title": "Order",
          "type": "integer"
        },
        "slug": {
          "title": "Slug",
          "type": "string"
        },
        "uuid": {
          "format": "uuid",
          "title": "Uuid",
          "type": "string"
        }
      },
      "required": [
        "uuid",
        "slug",
        "name",
        "description",
        "order",
        "learning_steps"
      ],
      "title": "Topic",
      "type": "object"
    }
  },
  "description": "A phase in the curriculum.\n\nPhases use ``slug`` (e.g. ``\"phase0\"``) and ``order`` (int ``0..6``)\nas their human keys. The slug is what shows up in URLs and is the\nprimary lookup key; ``order`` drives display ordering and is also\nused in URL paths today (``/phase/{order}``).",
  "properties": {
    "capstone": {
      "anyOf": [
        {
          "$ref": "#/$defs/PhaseCapstoneOverview"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "hands_on_verification": {
      "anyOf": [
        {
          "$ref": "#/$defs/PhaseHandsOnVerificationOverview"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "objectives": {
      "items": {
        "type": "string"
      },
      "title": "Objectives",
      "type": "array"
    },
    "order": {
      "default": 0,
      "title": "Order",
      "type": "integer"
    },
    "short_description": {
      "default": "",
      "title": "Short Description",
      "type": "string"
    },
    "slug": {
      "title": "Slug",
      "type": "string"
    },
    "topic_slugs": {
      "items": {
        "type": "string"
      },
      "title": "Topic Slugs",
      "type": "array"
    },
    "topics": {
      "items": {
        "$ref": "#/$defs/Topic"
      },
      "title": "Topics",
      "type": "array"
    },
    "uuid": {
      "format": "uuid",
      "title": "Uuid",
      "type": "string"
    }
  },
  "required": [
    "uuid",
    "name",
    "slug"
  ],
  "title": "Phase",
  "type": "object"
}
