                "repo_fork": "#/$defs/RepoForkRequirement",
                "security_scanning": "#/$defs/SecurityScanningRequirement"
              },
              "propertyName": "submission_type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/GithubProfileRequirement"
              },
              {
                "$ref": "#/$defs/ProfileReadmeRequirement"
              },
              {
                "$ref": "#/$defs/RepoForkRequirement"
              },
              {
                "$ref": "#/$defs/CtfTokenRequirement"
              },
              {
                "$ref": "#/$defs/NetworkingTokenRequirement"
