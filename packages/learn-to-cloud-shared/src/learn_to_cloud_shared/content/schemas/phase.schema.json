              },
              {
                "$ref": "#/$defs/DeployedApiRequirement"
              },
              {
                "$ref": "#/$defs/DevopsAnalysisRequirement"
              },
              {
                "$ref": "#/$defs/SecurityScanningRequirement"
              }
            ]
          },
          "title": "Requirements",
          "type": "array"
        }
      },
      "title": "PhaseHandsOnVerificationOverview",
