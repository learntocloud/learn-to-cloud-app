{
  "mcpServers": {
    "context7": {
      "type": "local",
      "command": "context7-mcp",
      "args": [],
      "tools": ["*"]
    },
    "tavily": {
      "type": "local",
      "command": "tavily-mcp",
      "args": [],
      "tools": ["*"]
    },
    "azure": {
      "type": "local",
      "command": "azmcp",
      "args": ["server", "start"],
      "tools": ["*"]
    },
    "aspire": {
      "type": "local",
      "command": "aspire",
      "args": ["agent", "mcp"],
      "tools": ["*"]
    },
    "playwright": {
      "type": "local",
      "command": "playwright-mcp",
      "args": ["--headless", "--isolated", "--no-sandbox"],
      "tools": ["*"]
    }
  }
}
