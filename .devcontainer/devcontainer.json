{
  "name": "Learn to Cloud",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/learn-to-cloud-app",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13",
      "installTools": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",
      "INSTALLYARNUSINGAPT": false
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "installBicep": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest",
      "tflint": "none",
      "terragrunt": "none"
    },
    "ghcr.io/va-h/devcontainers-features/uv:1": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.terminal.activateEnvironment": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "ruff.configurationPreference": "filesystemFirst"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "astral-sh.ty",
        "ms-azuretools.vscode-bicep",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "GitHub.copilot",
        "ms-azuretools.vscode-azure-mcp-server"
      ]
    }
  },
  "onCreateCommand": "bash .devcontainer/on-create.sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "UV_LINK_MODE": "copy"
  },
  "forwardPorts": [3000, 54320, 7071, 8000, 8082, 18888, 4317, 4318],
  "portsAttributes": {
    "3000": {
      "label": "Frontend (Vite)",
      "onAutoForward": "silent"
    },
    "54320": {
      "label": "Database (PostgreSQL)",
      "onAutoForward": "silent"
    },
    "8000": {
      "label": "API (FastAPI)",
      "onAutoForward": "silent"
    },
    "7071": {
      "label": "Verification Functions",
      "onAutoForward": "silent"
    },
    "8082": {
      "label": "Durable Task Scheduler Dashboard",
      "onAutoForward": "silent"
    },
    "18888": {
      "label": "Aspire Dashboard",
      "onAutoForward": "silent"
    },
    "4317": {
      "label": "Aspire OTLP gRPC",
      "onAutoForward": "silent"
    },
    "4318": {
      "label": "Aspire OTLP HTTP",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "vscode"
}
